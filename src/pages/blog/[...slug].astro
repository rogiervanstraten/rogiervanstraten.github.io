---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Rogier van Straten`} description={post.data.description}>
  <article>
    <a href="/" class="font-mono text-xs text-neutral-400 hover:text-neutral-900">&larr; home</a>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight text-neutral-900">
      {post.data.title}
    </h1>
    <p class="mt-2 font-mono text-xs text-neutral-400">
      {post.data.date.toISOString().slice(0, 10)}
    </p>
    <div class="prose prose-neutral mt-8 max-w-none prose-headings:font-semibold prose-a:text-neutral-900">
      <Content />
    </div>
  </article>
</Layout>
